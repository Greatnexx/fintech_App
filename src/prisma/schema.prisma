generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SERVICE_URI")      // since we are using SERVICE_URI from avien where our db is hosted prisma will now interact with the our db hosted on avien
}


model User {
  id             String         @id() @unique @default(uuid())
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  email          String         @unique
  first_name     String
  last_name      String
  phone_number   String         @unique
  password       String
  lastLogin      DateTime?
  profile        UserProfile?
  roles          UserRoles[]
  wallet         Wallet?
  sentTransactions        Transaction[]  @relation("SentTransactions")
  receivedTransactions    Transaction[]  @relation("ReceivedTransactions")
