model Roles {
  id             String         @id() @unique @default(uuid())
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  name           String         @unique
  users           UserRoles[]

}

model UserRoles {
  id             String         @id() @unique @default(uuid())
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  user_id        String
  role_id        String
  user           User           @relation(fields: [user_id], references: [id])
  role           Roles          @relation(fields: [role_id], references: [id])

}

model UserProfile {
  id             String        @id @default(uuid())
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  user_id         String       @unique
  profile_image   String
  address         String
  city            String
  lga             String
  state           String
  country         String
  zip_code        String?
  marital_status  String
  date_of_birth   DateTime
  user            User          @relation(fields: [user_id], references: [id])
}


model Wallet {
  id             String         @id() @unique @default(uuid())
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  user_id        String         @unique
  balance        Float          @default(0)
  account_number  String         @unique
  account_name      String
  currency        String         @default("NGN") 
  status         String         @default("active") 
  transactions    Transaction[]
  user           User           @relation(fields: [user_id], references: [id])
}
model Transaction {
  id           String            @id @default(uuid())
  created_at    DateTime          @default(now())
  updated_at     DateTime        @updatedAt
  type         TransactionType
  status       TransactionStatus
  amount       Float
  reference    String            @unique
  narration    String?
  sender       User?             @relation("SentTransactions", fields: [sender_id], references: [id])
  sender_id    String?
  receiver     User?             @relation("ReceivedTransactions", fields: [receiver_id], references: [id])
  receiver_id  String?
  wallet_id    String
  money_flow  MoneyFlow          @default(CREDIT) 
  wallet       Wallet            @relation(fields: [wallet_id], references: [id])
  balance_before Float           @default(0)
  balance_after  Float           @default(0)
  transaction_date DateTime      @default(now())
}

